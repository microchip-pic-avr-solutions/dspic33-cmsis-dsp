  37                 	
  38                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  39                 	;
  40                 	; _mchp_cfft_q31: Fixed-point (Q31) Complex DIF FFT (in-place).
  41                 	;
  42                 	; Description:
  43                 	;    Performs an in-place radix-2 Decimation-In-Frequency complex FFT on
  44                 	;    Q31 data. The input is expected in natural order; the output is
  45                 	;    produced in bit-reversed order.
  46                 	;
  47                 	;    An implicit scaling of 1/2 is applied at every stage to prevent
  48                 	;    overflow in fractional mode, so the final output is scaled by 1/N.
  49                 	;
  50                 	;    The implementation mirrors the structure of mchp_cfft_f32.s, replacing
  51                 	;    all FPU (float) operations with DSP engine fractional operations
  52                 	;    (lac.l / add.l / sub.l / mpy.l / mac.l / msc.l / sac.l / sacr.l)
  53                 	;    taken from the original fft_aa.s DIF butterfly.
  54                 	;
  55                 	; Operation:
  56                 	;    dstV[n] = FFTComplex(srcV[n]), 0 <= n < N
  57                 	;
  58                 	; Input:
  59                 	;    w0 = ptr to mchp_cfft_instance_q31 structure
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 2


  60                 	;    w1 = ptr to source/destination complex vector (in-place)
  61                 	;    w2 = ifft flag (0 = forward FFT, nonzero = inverse FFT)
  62                 	;    w3 = bit reverse flag (0 = no bit reversal, nonzero = apply bit reversal)
  63                 	;
  64                 	; Return:
  65                 	;    None
  66                 	;
  67                 	; System resources usage:
  68                 	;    {w0..w7}    used, not restored
  69                 	;    {w8..w14}   saved, used, restored
  70                 	;     AccuA      used, not restored
  71                 	;     AccuB      used, not restored
  72                 	;     CORCON     saved, used, restored
  73                 	;
  74                 	; Notes:
  75                 	;    - Input data magnitude of real and imaginary parts must be < 0.5
  76                 	;      to prevent saturation.
  77                 	;    - Output is in bit-reversed order; use bit-reverse copy if natural
  78                 	;      order is required.
  79                 	;
  80                 	;............................................................................
  81                 	
  82                 	    .extern    _mchp_scale_q31
  83                 	    .extern    _mchp_bitreversal_q31
  84                 	    .global    _mchp_cfft_q31                    ; export
  85                 	    .global    _FFTComplexIP_noBitRev_q31        ; export (core, no bit-reversal)
  86                 	
  87                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  88                 	;
  89                 	; _mchp_cfft_q31: Top-level entry point.
  90                 	;   Handles forward / inverse branching, then calls the core FFT.
  91                 	;
  92                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  93                 	
  94                 	_mchp_cfft_q31:
  95                 	
  96                 	;............................................................................
  97                 	; Extract instance structure fields.
  98                 	;   Assumed layout of mchp_cfft_instance_q31:
  99                 	;     [w0 + 0]  = fftLen (N)
 100                 	;     [w0 + 4]  = ptr to twiddle factor table (pTwiddle)
 101                 	;............................................................................
 102                 	
 103 000000  03 00 40 FD        mov.l      [w0 + 0], w4          ; w4 = fftLen = N.
 104 000004  13 00 50 FD        mov.l      [w0 + 4], w5          ; w5 = pTwiddle.
 105                 	
 106                 	;............................................................................
 107                 	; Branch on IFFT flag.
 108                 	;............................................................................
 109                 	
 110 000008  02 39 00 00        cp0.l      w2                     ; ifftFlag == 0 ? (32-bit compare)
 111 00000c  0A 00 00 A6        bra        z, _forward_path_q31   ; Yes => forward FFT.
 112                 	
 113                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 114                 	; Inverse FFT path.
 115                 	;   1. Call core FFT (no bit-reversal).
 116                 	;   2. Scale output by 1/N.
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 3


 117                 	;   3. Optionally apply bit-reversal.
 118                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 119                 	
 120                 	_inverse_path_q31:
 121                 	
 122                 	    ; Compute log2(N).
 123 000010  04 03              mov.l      w4, w0                ; w0 = N.
 124 000012  06 10              mov.l      #0, w6                ; w6 = log2 counter.
 125 000014  70 03              mov.l      w0, w7                ; w7 = N (temp).
 126                 	_log2_inv_q31:
 127 000016  77 2B              lsr.l      w7, w7                ; w7 >>= 1.
 128 000018  07 39 00 00        cp0.l      w7
 129 00001c  0A 00 00 A6        bra        z, _log2_inv_done_q31
 130 000020  16 74 00 00        add.l      #1, w6
 131 000024  0A 00 00 AE        bra        _log2_inv_q31
 132                 	_log2_inv_done_q31:
 133 000028  06 03              mov.l      w6, w0                ; w0 = log2(N).
 134                 	
 135                 	    ; Save context for scaling after FFT.
 136 00002a  F3 1F              push.l     w3                     ; Save bitRev flag.
 137 00002c  F4 1F              push.l     w4                     ; Save N.
 138 00002e  F1 1F              push.l     w1                     ; Save data pointer.
 139                 	
 140                 	    ; Setup parameters for core FFT.
 141 000030  32 03              mov.l      w2, w3                ; w3 = ifftFlag (nonzero = inverse).
 142 000032  25 03              mov.l      w5, w2                ; w2 = pTwiddle.
 143                 	                                      ; w0 = log2(N).
 144                 	                                      ; w1 = data pointer.
 145                 	                                      ; w3 = ifftFlag.
 146                 	
 147                 	    ; Call core FFT (no bit-reversal).
 148 000034  02 00 00 DE        call       _FFTComplexIP_noBitRev_q31
 149                 	
 150                 	    ; Restore context.
 151 000038  1F 1D              pop.l      w1                     ; w1 = data pointer (FFT output).
 152 00003a  4F 1D              pop.l      w4                     ; w4 = N.
 153 00003c  3F 1D              pop.l      w3                     ; w3 = bitRev flag.
 154                 	
 155                 	    ; Scale output by 1/N.
 156                 	    ; For Q31 in-place: each element is right-shifted by log2(N) bits,
 157                 	    ; which was already done implicitly (1/2 per stage). If additional
 158                 	    ; scaling is needed, call _mchp_scale_q31.
 159                 	    ;
 160                 	    ; Total complex elements = N, total 32-bit words = 2*N.
 161 00003e  01 03              mov.l      w1, w0                ; w0 = ptr to data (pSrcA = pDst).
 162 000040  11 03 00 00        mov.l      w1, w1                ; w1 = ptr to data (pSrcB, in-place).
 163 000044  08 01 12 A4        sl.l       w4, #1, w2            ; w2 = 2*N (total Q31 words to scale).
 164 000048  21 03 00 00        mov.l      w1, w2                ; w2 = pDst (in-place).
 165 00004c  08 01 13 A4        sl.l       w4, #1, w3            ; w3 = blockSize = 2*N.
 166                 	
 167                 	    ; Note: If implicit 1/2 per stage already provides 1/N scaling,
 168                 	    ; this call can be omitted. Included for completeness.
 169                 	    ; call     _mchp_scale_q31
 170                 	
 171 000050  0A 00 00 AE        bra        _cfft_done_q31
 172                 	
 173                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 4


 174                 	; Forward FFT path.
 175                 	;   1. Call core FFT (no bit-reversal).
 176                 	;   2. Optionally apply bit-reversal.
 177                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 178                 	
 179                 	_forward_path_q31:
 180                 	
 181                 	    ; Compute log2(N).
 182 000054  04 03              mov.l      w4, w0                ; w0 = N.
 183 000056  06 10              mov.l      #0, w6                ; w6 = log2 counter.
 184 000058  70 03              mov.l      w0, w7                ; w7 = N (temp).
 185                 	_log2_fwd_q31:
 186 00005a  77 2B              lsr.l      w7, w7                ; w7 >>= 1.
 187 00005c  07 39 00 00        cp0.l      w7
 188 000060  0A 00 00 A6        bra        z, _log2_fwd_done_q31
 189 000064  16 74 00 00        add.l      #1, w6
 190 000068  0A 00 00 AE        bra        _log2_fwd_q31
 191                 	_log2_fwd_done_q31:
 192 00006c  06 03              mov.l      w6, w0                ; w0 = log2(N).
 193                 	
 194                 	    ; Save bitRev flag and data pointer.
 195 00006e  F3 1F              push.l     w3                     ; Save bitRev flag.
 196 000070  F1 1F              push.l     w1                     ; Save data pointer.
 197 000072  F4 1F              push.l     w4                     ; Save N.
 198                 	
 199                 	    ; Setup parameters for core FFT.
 200 000074  03 10              mov.l      #0, w3                ; w3 = ifftFlag = 0 (forward FFT).
 201 000076  25 03              mov.l      w5, w2                ; w2 = pTwiddle.
 202                 	                                      ; w0 = log2(N).
 203                 	                                      ; w1 = data pointer.
 204                 	                                      ; w3 = ifftFlag.
 205                 	
 206                 	    ; Call core FFT (no bit-reversal).
 207 000078  02 00 00 DE        call       _FFTComplexIP_noBitRev_q31
 208                 	
 209                 	    ; Restore context.
 210 00007c  4F 1D              pop.l      w4                     ; w4 = N.
 211 00007e  1F 1D              pop.l      w1                     ; w1 = data pointer.
 212 000080  3F 1D              pop.l      w3                     ; w3 = bitRev flag.
 213                 	
 214                 	;............................................................................
 215                 	; Common exit (forward and inverse).
 216                 	;............................................................................
 217                 	
 218                 	_cfft_done_q31:
 219                 	
 220                 	    ; If w3 (bitRev flag) is nonzero, apply bit-reverse permutation
 221                 	    ; on the output buffer pointed to by w1, length N complex elements.
 222                 	    ; _mchp_bitreversal_q31 expects: w0=pSrc, w1=N, w2/w3=unused.
 223 000082  03 39              cp0.l      w3                     ; bitRev == 0?
 224 000084  0A 00 00 A6        bra        z, _cfft_skip_bitrev   ; Yes => skip bit-reversal.
 225 000088  01 03              mov.l      w1, w0                ; w0 = data pointer (pSrc).
 226 00008a  14 03              mov.l      w4, w1                ; w1 = N (fftLen).
 227 00008c  02 00 00 DE        call       _mchp_bitreversal_q31
 228                 	_cfft_skip_bitrev:
 229                 	
 230 000090  01 72              return
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 5


 231                 	
 232                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 233                 	;
 234                 	; _FFTComplexIP_noBitRev_q31: Core in-place radix-2 DIF FFT (Q31).
 235                 	;
 236                 	; Description:
 237                 	;    Performs log2(N) stages of radix-2 DIF butterflies using the DSP
 238                 	;    engine accumulators. Each butterfly computes:
 239                 	;
 240                 	;        upper_re = (Ar + Br) / 2
 241                 	;        upper_im = (Ai + Bi) / 2
 242                 	;        temp_re  = (Ar - Br) / 2
 243                 	;        temp_im  = (Ai - Bi) / 2
 244                 	;        lower_re = temp_re * Wr - temp_im * Wi
 245                 	;        lower_im = temp_re * Wi + temp_im * Wr
 246                 	;
 247                 	;    The 1/2 scaling per stage prevents overflow and results in a total
 248                 	;    output scaling of 1/N.
 249                 	;
 250                 	;    Input is in natural order; output is in bit-reversed order.
 251                 	;
 252                 	; Input:
 253                 	;    w0 = log2(N)
 254                 	;    w1 = ptr to complex data vector (in-place, interleaved Re/Im Q31)
 255                 	;    w2 = ptr to twiddle factor table (complex Q31, interleaved Re/Im)
 256                 	;    w3 = ifftFlag (0 = forward FFT, nonzero = inverse FFT)
 257                 	;
 258                 	; Return:
 259                 	;    w0 = ptr to output vector (same as input, in-place)
 260                 	;
 261                 	; System resources usage:
 262                 	;    {w0..w7}    used, not restored
 263                 	;    {w8..w14}   saved, used, restored
 264                 	;     AccuA      used, not restored
 265                 	;     AccuB      used, not restored
 266                 	;     CORCON     saved, used, restored
 267                 	;
 268                 	;............................................................................
 269                 	
 270                 	_FFTComplexIP_noBitRev_q31:
 271                 	
 272                 	;............................................................................
 273                 	; Save working registers.
 274                 	;............................................................................
 275                 	
 276 000092  F8 1F              push.l     w8                     ; Save w8.
 277 000094  F9 1F              push.l     w9                     ; Save w9.
 278 000096  FA 1F              push.l     w10                    ; Save w10.
 279 000098  FB 1F              push.l     w11                    ; Save w11.
 280 00009a  FC 1F              push.l     w12                    ; Save w12.
 281 00009c  FD 1F              push.l     w13                    ; Save w13.
 282 00009e  FE 1F              push.l     w14                    ; Save w14.
 283                 	
 284                 	;............................................................................
 285                 	; Prepare CORCON for fractional computation.
 286                 	;............................................................................
 287                 	
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 6


 288 0000a0  01 01 00 BF        push.l     CORCON                 ; Save 32-bit CORCON.
 289 0000a4  01 0F 00 80        MOV.l      #0xF0, w7             ; Fractional mode, saturation enabled,
 289         05 00 70 80 
 290 0000ac  1D 01 00 95        MOV.l      w7, CORCON            ; super-saturation, convergent rounding.
 291                 	
 292                 	;............................................................................
 293                 	; Save return value.
 294                 	;............................................................................
 295                 	
 296 0000b0  F1 1F              push.l     w1                     ; Save srcCV / dstCV pointer for return.
 297 0000b2  F3 1F              push.l     w3                     ; Save ifftFlag for twiddle sign control.
 298                 	
 299                 	;............................................................................
 300                 	; FFT initialization.
 301                 	;   w0 = log2(N) (also used as stage counter)
 302                 	;   w1 = ptr to complex data
 303                 	;   w2 = ptr to twiddle factors
 304                 	;   w3 = twiddle offset / number of butterflies per group (starts at 1)
 305                 	;   w8 = twiddle factor base pointer (rewound each butterfly set)
 306                 	;   w9 = N (total complex points, computed from log2N)
 307                 	;   [w15-4] = ifftFlag (on stack for butterfly sign control)
 308                 	;............................................................................
 309                 	
 310 0000b4  19 10 00 00        mov.l      #0x1, w9              ; w9 = 1 (to be shifted to compute N).
 311 0000b8  44 02 09 AD        sl.l       w9, w0, w9            ; w9 = N = (1 << log2N).
 312 0000bc  13 10              mov.l      #0x1, w3              ; Initialize butterflies per group = 1.
 313 0000be  82 03              mov.l      w2, w8                ; w8 -> WN(0) (twiddle factor base).
 314                 	
 315                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 316                 	; Stage loop: perform all log2(N) stages.
 317                 	;
 318                 	;   For stage k (k = 1 to log2N):
 319                 	;     - Number of butterfly groups = N / (2^k)          => w9
 320                 	;     - Number of butterflies per group = 2^(k-1)       => w3
 321                 	;     - Twiddle stride = butterflies * 8 bytes           => w7
 322                 	;     - Upper-to-lower offset = groups * 8 bytes         => w12
 323                 	;
 324                 	;   For the first stage: 1 butterfly per group, N/2 groups.
 325                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 326                 	
 327                 	_doStage_q31:
 328                 	
 329                 	    ; Update group counter: halve the number of groups.
 330 0000c0  99 2B              lsr.l      w9, w9                ; w9 = N / (2^k) (number of groups).
 331                 	
 332                 	    ; Compute upper-to-lower leg offset in bytes.
 333 0000c2  00 00              ; Each complex element = 2 x 4 bytes = 8 bytes.
 334 0000c4  48 02 3C A4        sl.l       w9, #3, w12           ; w12 = groups * 8 = offset to lower leg.
 335                 	
 336                 	    ; Initialize data pointer for this stage.
 337 0000c8  A1 03              mov.l      w1, w10               ; w10 -> data[0] (upper leg base).
 338                 	
 339                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 340                 	; Butterfly set loop (OUTER): iterate over butterflies per group.
 341                 	;   Matches F32 structure: outer loop over butterfly indices, inner loop
 342                 	;   over groups. Each butterfly index uses one twiddle factor across all
 343                 	;   groups; twiddle advances between groups within the inner loop.
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 7


 344                 	;
 345                 	;   w6  = butterfly index counter (outer, counts down from w3).
 346                 	;   w10 = upper leg base pointer (advances between butterfly indices).
 347                 	;   w8  = twiddle pointer (rewound after each inner loop pass).
 348                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 349                 	
 350 0000ca  63 03              mov.l      w3, w6                ; w6 = butterflies per group (outer counter).
 351                 	
 352                 	_doBflySet_q31:
 353                 	
 354                 	    ; Compute lower leg pointer from upper leg pointer + offset.
 355 0000cc  80 02 BC E1        add.l      w10, w12, w11         ; w11 = w10 + offset -> lower leg.
 356                 	
 357                 	    ; Setup inner loop counter: number of groups.
 358 0000d0  59 03              mov.l      w9, w5                ; w5 = nGrps (inner loop counter).
 359                 	
 360                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 361                 	; Group loop (INNER): perform one butterfly per group at the current
 362                 	; butterfly index, advancing the twiddle between groups.
 363                 	;
 364                 	;   DIF butterfly (Q31 fractional with 1/2 scaling):
 365                 	;
 366                 	;     Let A = upper leg (Ar + j*Ai), B = lower leg (Br + j*Bi)
 367                 	;     Let W = twiddle   (Wr + j*Wi)
 368                 	;
 369                 	;     Upper output:  Cr = (Ar + Br) / 2
 370                 	;                    Ci = (Ai + Bi) / 2
 371                 	;
 372                 	;     Difference:    diffR = (Ar - Br) / 2
 373                 	;                    diffI = (Ai - Bi) / 2
 374                 	;
 375                 	;     Lower output:  Dr = diffR * Wr - diffI * Wi
 376                 	;                    Di = diffR * Wi + diffI * Wr
 377                 	;
 378                 	;   Register usage within butterfly:
 379                 	;     w10 = upper leg pointer — post-incremented after sum stores
 380                 	;     w11 = lower leg pointer — post-incremented after lower stores
 381                 	;     w8  = twiddle pointer — advanced by twiddle stride per group
 382                 	;     w4  = diffR, then Wr
 383                 	;     w13 = diffI, then Wi
 384                 	;     w14 = Br, then Wr
 385                 	;     w7  = Bi, then Wi
 386                 	;     AccuA, AccuB = computation accumulators
 387                 	;
 388                 	;   Strategy: compute diffs into w4,w13 first (Ar/Ai read from memory,
 389                 	;   not yet overwritten), then compute and store sums (overwrites upper
 390                 	;   leg), then load twiddle and multiply diffs for lower output.
 391                 	;
 392                 	;   w6, w9 are NOT used inside this inner loop (no save/restore needed).
 393                 	;
 394                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 395                 	
 396                 	_doBfly_q31:
 397                 	
 398 0000d2  00 00              ;--- Load lower leg: Br, Bi ---
 399 0000d4  00 20 EB 83        mov.l      [w11], w14            ; w14 = Br.
 400 0000d8  13 00 7B FD        mov.l      [w11+4], w7           ; w7  = Bi.
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 8


 401                 	
 402                 	    ;--- Step 1: Compute differences (upper leg not yet overwritten). ---
 403                 	
 404                 	    ; diffR = (Ar - Br) / 2
 405 0000dc  03 20 0A C1        lac.l      [w10], a              ; a = Ar (original, still in place).
 406 0000e0  0F 00 0E C1        sub.l      w14, a                ; a = Ar - Br.
 407 0000e4  1B 00 04 C5        sacr.l     a, #1, w4             ; w4 = diffR = (Ar - Br) / 2.
 408                 	
 409                 	    ; diffI = (Ai - Bi) / 2
 410 0000e8  13 00 DA FD        mov.l      [w10+4], w13          ; w13 = Ai (load with mov.l, supports offset).
 411 0000ec  03 00 0D C1        lac.l      w13, a                ; a = Ai.
 412 0000f0  0F 00 07 C1        sub.l      w7, a                 ; a = Ai - Bi.
 413 0000f4  1B 00 0D C5        sacr.l     a, #1, w13            ; w13 = diffI = (Ai - Bi) / 2.
 414                 	
 415                 	    ;--- Step 2: Compute and store upper output (sums). Overwrites Ar, Ai. ---
 416                 	
 417                 	    ; Cr = (Ar + Br) / 2
 418 0000f8  03 20 0A C1        lac.l      [w10], a              ; a = Ar (still original).
 419 0000fc  0B 00 0E C1        add.l      w14, a                ; a = Ar + Br.
 420 000100  1B 0C 0A C5        sacr.l     a, #1, [w10++]        ; Store Cr at upper.re. Advance past Re.
 421                 	
 422                 	    ; Ci = (Ai + Bi) / 2  (Ai still at [w10] since we just advanced past Re)
 423 000104  03 20 0A C1        lac.l      [w10], a              ; a = Ai (still original, [w10] now points here).
 424 000108  0B 00 07 C1        add.l      w7, a                 ; a = Ai + Bi.
 425 00010c  1B 0C 0A C5        sacr.l     a, #1, [w10++]        ; Store Ci at upper.im. Advance past Im.
 426                 	                                      ; w10 -> next upper element.
 427                 	
 428                 	    ;--- Step 3: Load twiddle and compute lower output. ---
 429                 	
 430 000110  00 20 E8 83        mov.l      [w8], w14             ; w14 = Wr (reuse register, Br no longer needed).
 431 000114  13 00 78 FD        mov.l      [w8+4], w7            ; w7  = Wi (reuse register, Bi no longer needed).
 432                 	
 433                 	    ; For forward FFT (ifftFlag==0), negate Wi to use conjugate twiddle.
 434                 	    ; The twiddle table stores cos + j*sin (positive exponent).
 435                 	    ; Forward DFT requires e^{-j*2*pi*k/N} = cos - j*sin.
 436 000118  FE 0D              mov.l      [w15-4], w14          ; w14 = ifftFlag (peek from stack).
 437 00011a  0E 39              cp0.l      w14                   ; ifftFlag == 0?
 438 00011c  0E 00 00 A6        bra        nz, _skip_neg_wi_q31  ; If inverse, skip negation.
 439 000120  77 7B              neg.l      w7, w7                ; Forward: negate Wi.
 440 000122  00 00          _skip_neg_wi_q31:
 441 000124  00 20 E8 83        mov.l      [w8], w14             ; w14 = Wr (reload, was clobbered by ifftFlag peek).
 442                 	
 443                 	    ; Dr = diffR * Wr - diffI * Wi
 444 000128  3B 00 E4 D5        mpy.l      w4, w14, a            ; a  = diffR * Wr.
 445 00012c  3F 00 7D D1        msc.l      w13, w7, a            ; a -= diffI * Wi.  =>  a = Dr.
 446 000130  0B 0C 0B C5        sacr.l     a, [w11++]            ; Store Dr at lower.re. Advance past lower.re.
 447                 	
 448                 	    ; Di = diffR * Wi + diffI * Wr
 449 000134  3B 00 74 D7        mpy.l      w4, w7, b             ; b  = diffR * Wi.
 450 000138  3B 00 ED D3        mac.l      w13, w14, b           ; b += diffI * Wr.  =>  b = Di.
 451 00013c  0B 0C 0B C7        sacr.l     b, [w11++]            ; Store Di at lower.im. Advance past lower.im.
 452                 	                                      ; w11 -> next lower element.
 453                 	
 454                 	    ;--- Advance twiddle for next group ---
 455 000140  C8 00 37 A4        sl.l       w3, #3, w7            ; w7 = twiddle stride (recompute; was clobbered).
 456 000144  87 61              add.l      w8, w7, w8            ; w8 -> next group's twiddle factor.
 457 000146  00 00          
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 9


 458 000148  01 00 50 B8        DTB        w5, _doBfly_q31       ; Decrement group counter (w5);
 459                 	                                      ; branch to _doBfly_q31 if not zero.
 460                 	
 461                 	; } end group loop.
 462                 	
 463                 	;............................................................................
 464                 	; Advance to next butterfly index.
 465                 	;   Upper pointer (w10) has advanced past all upper legs for the current
 466                 	;   butterfly index. Skip past the lower leg region.
 467                 	;............................................................................
 468                 	
 469 00014c  AC 61              add.l      w12, w10, w10         ; w10 -> skip lower leg region.
 470                 	
 471                 	    ; Rewind twiddle pointer for next butterfly index.
 472 00014e  82 03              mov.l      w2, w8                ; Restore twiddle base pointer.
 473                 	
 474 000150  01 00 60 B8        DTB        w6, _doBflySet_q31    ; Decrement butterfly counter (w6);
 475                 	                                      ; branch to _doBflySet_q31 if not zero.
 476                 	
 477                 	; } end butterfly set loop.
 478                 	
 479                 	;............................................................................
 480                 	; Prepare for next stage.
 481                 	;............................................................................
 482                 	
 483                 	    ; Double the number of butterflies per group for next stage.
 484 000154  33 2D              sl.l       w3, w3                ; w3 *= 2 (butterflies per group doubles).
 485                 	
 486 000156  00 00              ; Check if more stages remain.
 487 000158  01 00 00 B8        dtb        w0, _doStage_q31      ; Decrement stage counter (w0 = log2N);
 488                 	                                      ; branch to _doStage_q31 if not zero.
 489                 	
 490                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 491                 	; FFT core completed.
 492                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 493                 	
 494                 	_completedFFT_q31:
 495                 	
 496                 	    ; Restore ifftFlag (discard) and return value.
 497 00015c  0F 1D              pop.l      w0                     ; Discard ifftFlag from stack.
 498 00015e  0F 1D              pop.l      w0                     ; w0 = ptr to output vector (srcCV / dstCV).
 499                 	
 500                 	;............................................................................
 501                 	; Restore CORCON and working registers.
 502                 	;............................................................................
 503                 	
 504 000160  01 01 00 BD        pop.l      CORCON                 ; Restore 32-bit CORCON.
 505 000164  EF 1D              pop.l      w14                    ; Restore w14.
 506 000166  DF 1D              pop.l      w13                    ; Restore w13.
 507 000168  CF 1D              pop.l      w12                    ; Restore w12.
 508 00016a  BF 1D              pop.l      w11                    ; Restore w11.
 509 00016c  AF 1D              pop.l      w10                    ; Restore w10.
 510 00016e  9F 1D              pop.l      w9                     ; Restore w9.
 511 000170  8F 1D              pop.l      w8                     ; Restore w8.
 512                 	
 513 000172  01 72              return
 514                 	
