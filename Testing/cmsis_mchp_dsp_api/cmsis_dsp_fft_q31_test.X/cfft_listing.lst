  37                 	
  38                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  39                 	;
  40                 	; _mchp_cfft_q31: Fixed-point (Q31) Complex DIF FFT (in-place).
  41                 	;
  42                 	; Description:
  43                 	;    Performs an in-place radix-2 Decimation-In-Frequency complex FFT on
  44                 	;    Q31 data. The input is expected in natural order; the output is
  45                 	;    produced in bit-reversed order.
  46                 	;
  47                 	;    An implicit scaling of 1/2 is applied at every stage to prevent
  48                 	;    overflow in fractional mode, so the final output is scaled by 1/N.
  49                 	;
  50                 	;    The implementation mirrors the structure of mchp_cfft_f32.s, replacing
  51                 	;    all FPU (float) operations with DSP engine fractional operations
  52                 	;    (lac.l / add.l / sub.l / mpy.l / mac.l / msc.l / sac.l / sacr.l)
  53                 	;    taken from the original fft_aa.s DIF butterfly.
  54                 	;
  55                 	; Operation:
  56                 	;    dstV[n] = FFTComplex(srcV[n]), 0 <= n < N
  57                 	;
  58                 	; Input:
  59                 	;    w0 = ptr to mchp_cfft_instance_q31 structure
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 2


  60                 	;    w1 = ptr to source/destination complex vector (in-place)
  61                 	;    w2 = ifft flag (0 = forward FFT, nonzero = inverse FFT)
  62                 	;    w3 = bit reverse flag (0 = no bit reversal, nonzero = apply bit reversal)
  63                 	;
  64                 	; Return:
  65                 	;    None
  66                 	;
  67                 	; System resources usage:
  68                 	;    {w0..w7}    used, not restored
  69                 	;    {w8..w14}   saved, used, restored
  70                 	;     AccuA      used, not restored
  71                 	;     AccuB      used, not restored
  72                 	;     CORCON     saved, used, restored
  73                 	;
  74                 	; Notes:
  75                 	;    - Input data magnitude of real and imaginary parts must be < 0.5
  76                 	;      to prevent saturation.
  77                 	;    - Output is in bit-reversed order; use bit-reverse copy if natural
  78                 	;      order is required.
  79                 	;
  80                 	;............................................................................
  81                 	
  82                 	    .extern    _mchp_scale_q31
  83                 	    .global    _mchp_cfft_q31                    ; export
  84                 	    .global    _FFTComplexIP_noBitRev_q31        ; export (core, no bit-reversal)
  85                 	
  86                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  87                 	;
  88                 	; _mchp_cfft_q31: Top-level entry point.
  89                 	;   Handles forward / inverse branching, then calls the core FFT.
  90                 	;
  91                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  92                 	
  93                 	_mchp_cfft_q31:
  94                 	
  95                 	;............................................................................
  96                 	; Extract instance structure fields.
  97                 	;   Assumed layout of mchp_cfft_instance_q31:
  98                 	;     [w0 + 0]  = fftLen (N)
  99                 	;     [w0 + 4]  = ptr to twiddle factor table (pTwiddle)
 100                 	;............................................................................
 101                 	
 102 000000  03 00 40 FD        mov.l      [w0 + 0], w4          ; w4 = fftLen = N.
 103 000004  13 00 50 FD        mov.l      [w0 + 4], w5          ; w5 = pTwiddle.
 104                 	
 105                 	;............................................................................
 106                 	; Branch on IFFT flag.
 107                 	;............................................................................
 108                 	
 109 000008  02 39 00 00        cp0.l      w2                     ; ifftFlag == 0 ? (32-bit compare)
 110 00000c  0A 00 00 A6        bra        z, _forward_path_q31   ; Yes => forward FFT.
 111                 	
 112                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 113                 	; Inverse FFT path.
 114                 	;   1. Call core FFT (no bit-reversal).
 115                 	;   2. Scale output by 1/N.
 116                 	;   3. Optionally apply bit-reversal.
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 3


 117                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 118                 	
 119                 	_inverse_path_q31:
 120                 	
 121                 	    ; Compute log2(N).
 122 000010  04 03              mov.l      w4, w0                ; w0 = N.
 123 000012  06 10              mov.l      #0, w6                ; w6 = log2 counter.
 124 000014  70 03              mov.l      w0, w7                ; w7 = N (temp).
 125                 	_log2_inv_q31:
 126 000016  77 2B              lsr.l      w7, w7                ; w7 >>= 1.
 127 000018  07 39 00 00        cp0.l      w7
 128 00001c  0A 00 00 A6        bra        z, _log2_inv_done_q31
 129 000020  16 74 00 00        add.l      #1, w6
 130 000024  0A 00 00 AE        bra        _log2_inv_q31
 131                 	_log2_inv_done_q31:
 132 000028  06 03              mov.l      w6, w0                ; w0 = log2(N).
 133                 	
 134                 	    ; Save context for scaling after FFT.
 135 00002a  F3 1F              push.l     w3                     ; Save bitRev flag.
 136 00002c  F4 1F              push.l     w4                     ; Save N.
 137 00002e  F1 1F              push.l     w1                     ; Save data pointer.
 138                 	
 139                 	    ; Setup parameters for core FFT.
 140 000030  25 03              mov.l      w5, w2                ; w2 = pTwiddle.
 141                 	                                      ; w0 = log2(N).
 142                 	                                      ; w1 = data pointer.
 143                 	
 144 000032  00 00              ; Call core FFT (no bit-reversal).
 145 000034  02 00 00 DE        call       _FFTComplexIP_noBitRev_q31
 146                 	
 147                 	    ; Restore context.
 148 000038  1F 1D              pop.l      w1                     ; w1 = data pointer (FFT output).
 149 00003a  4F 1D              pop.l      w4                     ; w4 = N.
 150 00003c  3F 1D              pop.l      w3                     ; w3 = bitRev flag.
 151                 	
 152                 	    ; Scale output by 1/N.
 153                 	    ; For Q31 in-place: each element is right-shifted by log2(N) bits,
 154                 	    ; which was already done implicitly (1/2 per stage). If additional
 155                 	    ; scaling is needed, call _mchp_scale_q31.
 156                 	    ;
 157                 	    ; Total complex elements = N, total 32-bit words = 2*N.
 158 00003e  01 03              mov.l      w1, w0                ; w0 = ptr to data (pSrcA = pDst).
 159 000040  11 03 00 00        mov.l      w1, w1                ; w1 = ptr to data (pSrcB, in-place).
 160 000044  08 01 12 A4        sl.l       w4, #1, w2            ; w2 = 2*N (total Q31 words to scale).
 161 000048  21 03 00 00        mov.l      w1, w2                ; w2 = pDst (in-place).
 162 00004c  08 01 13 A4        sl.l       w4, #1, w3            ; w3 = blockSize = 2*N.
 163                 	
 164                 	    ; Note: If implicit 1/2 per stage already provides 1/N scaling,
 165                 	    ; this call can be omitted. Included for completeness.
 166                 	    ; call     _mchp_scale_q31
 167                 	
 168 000050  0A 00 00 AE        bra        _cfft_done_q31
 169                 	
 170                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 171                 	; Forward FFT path.
 172                 	;   1. Call core FFT (no bit-reversal).
 173                 	;   2. Optionally apply bit-reversal.
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 4


 174                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 175                 	
 176                 	_forward_path_q31:
 177                 	
 178                 	    ; Compute log2(N).
 179 000054  04 03              mov.l      w4, w0                ; w0 = N.
 180 000056  06 10              mov.l      #0, w6                ; w6 = log2 counter.
 181 000058  70 03              mov.l      w0, w7                ; w7 = N (temp).
 182                 	_log2_fwd_q31:
 183 00005a  77 2B              lsr.l      w7, w7                ; w7 >>= 1.
 184 00005c  07 39 00 00        cp0.l      w7
 185 000060  0A 00 00 A6        bra        z, _log2_fwd_done_q31
 186 000064  16 74 00 00        add.l      #1, w6
 187 000068  0A 00 00 AE        bra        _log2_fwd_q31
 188                 	_log2_fwd_done_q31:
 189 00006c  06 03              mov.l      w6, w0                ; w0 = log2(N).
 190                 	
 191                 	    ; Save bitRev flag and data pointer.
 192 00006e  F3 1F              push.l     w3                     ; Save bitRev flag.
 193 000070  F1 1F              push.l     w1                     ; Save data pointer.
 194 000072  F4 1F              push.l     w4                     ; Save N.
 195                 	
 196                 	    ; Setup parameters for core FFT.
 197 000074  25 03              mov.l      w5, w2                ; w2 = pTwiddle.
 198                 	                                      ; w0 = log2(N).
 199                 	                                      ; w1 = data pointer.
 200                 	
 201 000076  00 00              ; Call core FFT (no bit-reversal).
 202 000078  02 00 00 DE        call       _FFTComplexIP_noBitRev_q31
 203                 	
 204                 	    ; Restore context.
 205 00007c  4F 1D              pop.l      w4                     ; w4 = N.
 206 00007e  1F 1D              pop.l      w1                     ; w1 = data pointer.
 207 000080  3F 1D              pop.l      w3                     ; w3 = bitRev flag.
 208                 	
 209                 	;............................................................................
 210                 	; Common exit (forward and inverse).
 211                 	;............................................................................
 212                 	
 213                 	_cfft_done_q31:
 214                 	
 215                 	    ; TODO: If w3 (bitRev flag) is nonzero, apply bit-reverse permutation
 216                 	    ;       on the output buffer pointed to by w1, length N complex elements.
 217                 	    ;       (Bit-reverse function not shown; add call here if needed.)
 218                 	
 219 000082  01 72              return
 220                 	
 221                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 222                 	;
 223                 	; _FFTComplexIP_noBitRev_q31: Core in-place radix-2 DIF FFT (Q31).
 224                 	;
 225                 	; Description:
 226                 	;    Performs log2(N) stages of radix-2 DIF butterflies using the DSP
 227                 	;    engine accumulators. Each butterfly computes:
 228                 	;
 229                 	;        upper_re = (Ar + Br) / 2
 230                 	;        upper_im = (Ai + Bi) / 2
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 5


 231                 	;        temp_re  = (Ar - Br) / 2
 232                 	;        temp_im  = (Ai - Bi) / 2
 233                 	;        lower_re = temp_re * Wr - temp_im * Wi
 234                 	;        lower_im = temp_re * Wi + temp_im * Wr
 235                 	;
 236                 	;    The 1/2 scaling per stage prevents overflow and results in a total
 237                 	;    output scaling of 1/N.
 238                 	;
 239                 	;    Input is in natural order; output is in bit-reversed order.
 240                 	;
 241                 	; Input:
 242                 	;    w0 = log2(N)
 243                 	;    w1 = ptr to complex data vector (in-place, interleaved Re/Im Q31)
 244                 	;    w2 = ptr to twiddle factor table (complex Q31, interleaved Re/Im)
 245                 	;
 246                 	; Return:
 247                 	;    w0 = ptr to output vector (same as input, in-place)
 248                 	;
 249                 	; System resources usage:
 250                 	;    {w0..w7}    used, not restored
 251                 	;    {w8..w14}   saved, used, restored
 252                 	;     AccuA      used, not restored
 253                 	;     AccuB      used, not restored
 254                 	;     CORCON     saved, used, restored
 255                 	;
 256                 	;............................................................................
 257                 	
 258                 	_FFTComplexIP_noBitRev_q31:
 259                 	
 260                 	;............................................................................
 261                 	; Save working registers.
 262                 	;............................................................................
 263                 	
 264 000084  F8 1F              push.l     w8                     ; Save w8.
 265 000086  F9 1F              push.l     w9                     ; Save w9.
 266 000088  FA 1F              push.l     w10                    ; Save w10.
 267 00008a  FB 1F              push.l     w11                    ; Save w11.
 268 00008c  FC 1F              push.l     w12                    ; Save w12.
 269 00008e  FD 1F              push.l     w13                    ; Save w13.
 270 000090  FE 1F              push.l     w14                    ; Save w14.
 271                 	
 272                 	;............................................................................
 273                 	; Prepare CORCON for fractional computation.
 274                 	;............................................................................
 275 000092  00 00          
 276 000094  01 01 00 BF        push.l     CORCON                 ; Save 32-bit CORCON.
 277 000098  01 0F 00 80        MOV.l      #0xF0, w7             ; Fractional mode, saturation enabled,
 277         05 00 70 80 
 278 0000a0  1D 01 00 95        MOV.l      w7, CORCON            ; super-saturation, convergent rounding.
 279                 	
 280                 	;............................................................................
 281                 	; Save return value.
 282                 	;............................................................................
 283                 	
 284 0000a4  F1 1F              push.l     w1                     ; Save srcCV / dstCV pointer for return.
 285                 	
 286                 	;............................................................................
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 6


 287                 	; FFT initialization.
 288                 	;   w0 = log2(N) (also used as stage counter)
 289                 	;   w1 = ptr to complex data
 290                 	;   w2 = ptr to twiddle factors
 291                 	;   w3 = twiddle offset / number of butterflies per group (starts at 1)
 292                 	;   w8 = twiddle factor base pointer (rewound each butterfly set)
 293                 	;   w9 = N (total complex points, computed from log2N)
 294                 	;............................................................................
 295                 	
 296 0000a6  19 10              mov.l      #0x1, w9              ; w9 = 1 (to be shifted to compute N).
 297 0000a8  44 02 09 AD        sl.l       w9, w0, w9            ; w9 = N = (1 << log2N).
 298 0000ac  13 10              mov.l      #0x1, w3              ; Initialize butterflies per group = 1.
 299 0000ae  82 03              mov.l      w2, w8                ; w8 -> WN(0) (twiddle factor base).
 300                 	
 301                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 302                 	; Stage loop: perform all log2(N) stages.
 303                 	;
 304                 	;   For stage k (k = 1 to log2N):
 305                 	;     - Number of butterfly groups = N / (2^k)          => w9
 306                 	;     - Number of butterflies per group = 2^(k-1)       => w3
 307                 	;     - Twiddle stride = butterflies * 8 bytes           => w7
 308                 	;     - Upper-to-lower offset = groups * 8 bytes         => w12
 309                 	;
 310                 	;   For the first stage: 1 butterfly per group, N/2 groups.
 311                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 312                 	
 313                 	_doStage_q31:
 314                 	
 315                 	    ; Update group counter: halve the number of groups.
 316 0000b0  99 2B              lsr.l      w9, w9                ; w9 = N / (2^k) (number of groups).
 317                 	
 318                 	    ; Compute upper-to-lower leg offset in bytes.
 319 0000b2  00 00              ; Each complex element = 2 x 4 bytes = 8 bytes.
 320 0000b4  48 02 3C A4        sl.l       w9, #3, w12           ; w12 = groups * 8 = offset to lower leg.
 321                 	
 322                 	    ; Compute twiddle stride in bytes.
 323 0000b8  C8 00 37 A4        sl.l       w3, #3, w7            ; w7 = butterflies * 8 = twiddle stride.
 324                 	
 325                 	    ; Initialize group counter and data pointer for this stage.
 326 0000bc  69 03              mov.l      w9, w6                ; w6 = number of groups (set loop counter).
 327 0000be  A1 03              mov.l      w1, w10               ; w10 -> data[0] (upper leg base).
 328                 	
 329                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 330                 	; Butterfly set loop: iterate over all groups for this stage.
 331                 	;   w6  = group counter.
 332                 	;   w10 = upper leg pointer (advances between groups).
 333                 	;   w8  = twiddle pointer (rewound to base each group).
 334                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 335                 	
 336                 	_doBflySet_q31:
 337                 	
 338                 	    ; Compute lower leg pointer from upper leg pointer + offset.
 339 0000c0  80 02 BC E1        add.l      w10, w12, w11         ; w11 = w10 + offset -> lower leg.
 340                 	
 341                 	    ; Setup butterfly counter within this group.
 342 0000c4  53 03              mov.l      w3, w5                ; w5 = butterflies per group.
 343 0000c6  E8 03              mov.l      w8, w14               ; w14 = twiddle pointer for this group.
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 7


 344                 	
 345                 	    ; Save registers that the butterfly loop clobbers.
 346                 	    ; w6 = group counter (outer DTB), w9 = stage group count (next stage).
 347 0000c8  F6 1F              push.l     w6                     ; Save group counter.
 348 0000ca  F9 1F              push.l     w9                     ; Save stage group count.
 349                 	
 350                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 351                 	; Butterfly loop: perform each butterfly in the group.
 352                 	;
 353                 	;   DIF butterfly (Q31 fractional with 1/2 scaling):
 354                 	;
 355                 	;     Let A = upper leg (Ar + j*Ai), B = lower leg (Br + j*Bi)
 356                 	;     Let W = twiddle   (Wr + j*Wi)
 357                 	;
 358                 	;     Upper output:  Cr = (Ar + Br) / 2
 359                 	;                    Ci = (Ai + Bi) / 2
 360                 	;
 361                 	;     Difference:    diffR = (Ar - Br) / 2
 362                 	;                    diffI = (Ai - Bi) / 2
 363                 	;
 364                 	;     Lower output:  Dr = diffR * Wr - diffI * Wi
 365                 	;                    Di = diffR * Wi + diffI * Wr
 366                 	;
 367                 	;   Register usage within butterfly:
 368                 	;     w10 = upper leg pointer (Ar, Ai) — post-incremented after store
 369                 	;     w11 = lower leg pointer (Br, Bi) — post-incremented after store
 370                 	;     w14 = twiddle pointer (Wr, Wi) — advanced by twiddle stride
 371                 	;     w4  = Wr (twiddle real)
 372                 	;     w13 = Wi (twiddle imaginary)
 373                 	;     w6  = Br (scratch, clobbers saved group counter)
 374                 	;     w7  = Bi (scratch, clobbers twiddle stride)
 375                 	;     w8  = Ar then diffR
 376                 	;     w9  = Ai then diffI
 377                 	;     AccuA, AccuB = computation accumulators
 378                 	;
 379                 	;   NOTE: w6, w7, w9 are saved/restored around this loop.
 380                 	;   w7 (twiddle stride) is used for twiddle advance BEFORE being clobbered.
 381                 	;   w8 (twiddle base) is restored per-group after loop.
 382                 	;
 383                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 384                 	
 385                 	_doBfly_q31:
 386                 	
 387                 	    ;--- Load twiddle factors ---
 388 0000cc  00 20 4E 83        mov.l      [w14], w4             ; w4  = Wr (twiddle real part).
 389 0000d0  1D 0E              mov.l      [w14+4], w13          ; w13 = Wi (twiddle imaginary part).
 390                 	
 391                 	    ;--- Advance twiddle pointer BEFORE w7 is clobbered ---
 392 0000d2  E7 61              add.l      w14, w7, w14          ; w14 -> next twiddle factor.
 393                 	                                      ; (w7 = twiddle stride, still valid here.)
 394                 	
 395                 	    ;--- Load lower leg: Br, Bi ---
 396 0000d4  00 20 6B 83        mov.l      [w11], w6             ; w6 = Br.
 397 0000d8  13 00 7B FD        mov.l      [w11+4], w7           ; w7 = Bi. (clobbers twiddle stride, OK.)
 398                 	
 399                 	    ;--- Load upper leg: Ar, Ai using mov.l (supports [wN+offset]) ---
 400 0000dc  00 20 8A 83        mov.l      [w10], w8             ; w8 = Ar.
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 8


 401 0000e0  13 00 9A FD        mov.l      [w10+4], w9           ; w9 = Ai.
 402                 	
 403                 	    ;=== DIF Butterfly ===
 404                 	    ;
 405                 	    ; Strategy: compute sums first (store to upper leg), then diffs
 406                 	    ; (w8/w9 still hold original Ar/Ai for diff computation).
 407                 	
 408                 	    ; Step 1: Compute and store upper output (sums). Overwrites upper leg.
 409                 	
 410                 	    ; Cr = (Ar + Br) / 2
 411 0000e4  03 00 08 C1        lac.l      w8, a                 ; a = Ar.
 412 0000e8  0B 00 06 C1        add.l      w6, a                 ; a = Ar + Br.
 413 0000ec  1B 0C 0A C5        sacr.l     a, #1, [w10++]        ; Store Cr at upper.re. Advance past Re.
 414                 	
 415                 	    ; Ci = (Ai + Bi) / 2
 416 0000f0  03 00 09 C1        lac.l      w9, a                 ; a = Ai.
 417 0000f4  0B 00 07 C1        add.l      w7, a                 ; a = Ai + Bi.
 418 0000f8  1B 0C 0A C5        sacr.l     a, #1, [w10++]        ; Store Ci at upper.im. Advance past Im.
 419                 	                                      ; w10 -> next upper element.
 420                 	
 421                 	    ; Step 2: Compute differences (w8=Ar, w9=Ai still valid).
 422                 	
 423                 	    ; diffR = (Ar - Br) / 2
 424 0000fc  03 00 08 C1        lac.l      w8, a                 ; a = Ar.
 425 000100  0F 00 06 C1        sub.l      w6, a                 ; a = Ar - Br.
 426 000104  1B 00 08 C5        sacr.l     a, #1, w8             ; w8 = diffR = (Ar - Br) / 2.
 427                 	
 428                 	    ; diffI = (Ai - Bi) / 2
 429 000108  03 00 09 C1        lac.l      w9, a                 ; a = Ai.
 430 00010c  0F 00 07 C1        sub.l      w7, a                 ; a = Ai - Bi.
 431 000110  1B 00 09 C5        sacr.l     a, #1, w9             ; w9 = diffI = (Ai - Bi) / 2.
 432                 	
 433                 	    ; Step 3: Compute lower output using twiddle multiplication.
 434                 	
 435                 	    ; Dr = diffR * Wr - diffI * Wi
 436 000114  3B 00 48 D5        mpy.l      w8, w4, a             ; a  = diffR * Wr.
 437 000118  3F 00 D9 D1        msc.l      w9, w13, a            ; a -= diffI * Wi.
 438                 	                                      ; a  = Dr.
 439 00011c  0B 0C 0B C5        sacr.l     a, [w11++]            ; Store Dr at lower.re. Advance past lower.re.
 440                 	
 441                 	    ; Di = diffR * Wi + diffI * Wr
 442 000120  3B 00 D8 D7        mpy.l      w8, w13, b            ; b  = diffR * Wi.
 443 000124  3B 00 49 D3        mac.l      w9, w4, b             ; b += diffI * Wr.
 444                 	                                      ; b  = Di.
 445 000128  0B 0C 0B C7        sacr.l     b, [w11++]            ; Store Di at lower.im. Advance past lower.im.
 446                 	                                      ; w11 -> next lower element.
 447                 	
 448 00012c  01 00 50 B8        DTB        w5, _doBfly_q31       ; Decrement butterfly counter (w5);
 449                 	                                      ; branch to _doBfly_q31 if not zero.
 450                 	
 451                 	; } end butterfly loop.
 452                 	
 453                 	    ; Restore registers clobbered by butterfly loop.
 454 000130  9F 1D              pop.l      w9                     ; Restore stage group count.
 455 000132  6F 1D              pop.l      w6                     ; Restore group counter.
 456                 	
 457                 	;............................................................................
MPLAB XC-DSC ASSEMBLY Listing:  ../../../Source/TransformFunctions/mchp_cfft_q31.s 			page 9


 458                 	; Advance to next butterfly set (group).
 459                 	;   Upper pointer (w10) has already advanced past this group's upper legs.
 460                 	;   Need to skip over this group's lower legs to reach the next group's
 461                 	;   upper legs.
 462                 	;............................................................................
 463                 	
 464 000134  AC 61              add.l      w12, w10, w10         ; w10 -> next group's upper leg
 465                 	                                      ;        (skip lower leg region).
 466                 	
 467                 	    ; Rewind twiddle pointer for next group.
 468 000136  82 03              mov.l      w2, w8                ; Restore twiddle base pointer.
 469                 	
 470 000138  01 00 60 B8        DTB        w6, _doBflySet_q31    ; Decrement group counter (w6);
 471                 	                                      ; branch to _doBflySet_q31 if not zero.
 472                 	
 473                 	; } end butterfly set loop.
 474                 	
 475                 	;............................................................................
 476                 	; Prepare for next stage.
 477                 	;............................................................................
 478                 	
 479                 	    ; Double the number of butterflies per group for next stage.
 480 00013c  33 2D              sl.l       w3, w3                ; w3 *= 2 (butterflies per group doubles).
 481                 	
 482 00013e  00 00              ; Check if more stages remain.
 483 000140  01 00 00 B8        dtb        w0, _doStage_q31      ; Decrement stage counter (w0 = log2N);
 484                 	                                      ; branch to _doStage_q31 if not zero.
 485                 	
 486                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 487                 	; FFT core completed.
 488                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 489                 	
 490                 	_completedFFT_q31:
 491                 	
 492                 	    ; Restore return value.
 493 000144  0F 1D              pop.l      w0                     ; w0 = ptr to output vector (srcCV / dstCV).
 494                 	
 495                 	;............................................................................
 496                 	; Restore CORCON and working registers.
 497                 	;............................................................................
 498 000146  00 00          
 499 000148  01 01 00 BD        pop.l      CORCON                 ; Restore 32-bit CORCON.
 500 00014c  EF 1D              pop.l      w14                    ; Restore w14.
 501 00014e  DF 1D              pop.l      w13                    ; Restore w13.
 502 000150  CF 1D              pop.l      w12                    ; Restore w12.
 503 000152  BF 1D              pop.l      w11                    ; Restore w11.
 504 000154  AF 1D              pop.l      w10                    ; Restore w10.
 505 000156  9F 1D              pop.l      w9                     ; Restore w9.
 506 000158  8F 1D              pop.l      w8                     ; Restore w8.
 507                 	
 508 00015a  01 72              return
 509                 	
 510                 	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 511                 	
 512                 	    .end
